PORT=3005
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vinbooking_db
DB_USER=vinbooking_user
DB_PASSWORD=password

# External Services
AUTH_SERVICE_URL=http://auth-service:3001
BOOKING_SERVICE_URL=http://booking-service:3004
EMAIL_SERVICE_URL=http://email-service:3006

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id

# Security
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
NODE_ENV=development
ENCRYPTION_KEY=your-32-character-encryption-key

# Business Rules
MIN_PAYMENT_AMOUNT=5.00
MAX_PAYMENT_AMOUNT=5000.00
REFUND_DEADLINE_HOURS=24
PAYMENT_TIMEOUT_MINUTES=30