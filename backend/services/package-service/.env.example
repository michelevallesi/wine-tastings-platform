PORT=3003
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vinbooking_db
DB_USER=vinbooking_user
DB_PASSWORD=password

# External Services
AUTH_SERVICE_URL=http://auth-service:3001
BOOKING_SERVICE_URL=http://booking-service:3004
PRODUCER_SERVICE_URL=http://producer-service:3002

# File Upload
MAX_IMAGE_SIZE=10485760
MAX_IMAGES_PER_PACKAGE=10
SUPPORTED_IMAGE_FORMATS=jpeg,jpg,png,webp
UPLOAD_DIR=uploads
IMAGE_QUALITY=85

# Business Rules
MIN_PRICE=5.00
MAX_PRICE=1000.00
MIN_PARTICIPANTS=1
MAX_PARTICIPANTS=50
MIN_DURATION_MINUTES=30
MAX_DURATION_MINUTES=480
ADVANCE_BOOKING_DAYS=365

# Security
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
NODE_ENV=development