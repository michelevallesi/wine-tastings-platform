# ============================================================
# Wine Tastings Platform — Environment Variables
# Copy this file to .env and fill in all values before running
# ============================================================

# --- General ---
NODE_ENV=production

# --- JWT (REQUIRED — use a long random string in production) ---
JWT_SECRET=change-me-to-a-long-random-secret

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.com

# --- Database (PostgreSQL) ---
# Used by all backend services
DATABASE_URL=postgresql://wine_user:wine_pass@postgres:5432/wine_tastings

# --- Redis ---
REDIS_URL=redis://:wine_redis_pass@redis:6379

# --- Stripe (payment-service) ---
# Free account at https://stripe.com — no monthly fee, pay per transaction.
# Use sk_test_... keys for sandbox (free). Use sk_live_... in production.
# When unset, the service runs in mock mode (no real charges made).
STRIPE_SECRET_KEY=sk_test_...
# URL Stripe redirects to after 3D Secure authentication
STRIPE_RETURN_URL=https://your-frontend-domain.com/booking/confirm

# --- Mollie (payment-service) ---
# EU-native gateway — free account at https://mollie.com, no monthly fee.
# Use test_... keys for sandbox (free). Use live_... in production.
# When unset, the service runs in mock mode.
MOLLIE_API_KEY=test_...
# URL Mollie redirects to after hosted payment page
MOLLIE_REDIRECT_URL=https://your-frontend-domain.com/booking/confirm

# --- PayPal (payment-service, legacy) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Email / SMTP (notification-service) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password

# --- AWS S3 (file-service) ---
AWS_S3_BUCKET=wine-tastings-uploads
# AWS credentials must also be set (via IAM role or env vars):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# --- Local file storage fallback (file-service) ---
FILE_STORAGE_PATH=/uploads

# --- Grafana monitoring ---
# GF_SECURITY_ADMIN_PASSWORD=change-me
